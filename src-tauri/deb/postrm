#!/bin/sh
set -e

if [ "$1" = "purge" ] || [ "$1" = "remove" ]; then
    rm -f /usr/share/mime/packages/asset-snapshot.xml
    if command -v update-mime-database >/dev/null 2>&1; then
        update-mime-database /usr/share/mime || true
    fi
    if command -v update-desktop-database >/dev/null 2>&1; then
        update-desktop-database /usr/share/applications || true
    fi

    # Remove MIME type icon files
    rm -f /usr/share/icons/hicolor/scalable/mimetypes/application-vnd.asset-snapshot.sqlite3.svg
    rm -f /usr/share/icons/hicolor/16x16/mimetypes/application-vnd.asset-snapshot.sqlite3.png
    rm -f /usr/share/icons/hicolor/24x24/mimetypes/application-vnd.asset-snapshot.sqlite3.png
    rm -f /usr/share/icons/hicolor/32x32/mimetypes/application-vnd.asset-snapshot.sqlite3.png
    rm -f /usr/share/icons/hicolor/48x48/mimetypes/application-vnd.asset-snapshot.sqlite3.png
    rm -f /usr/share/icons/hicolor/64x64/mimetypes/application-vnd.asset-snapshot.sqlite3.png
    rm -f /usr/share/icons/hicolor/128x128/mimetypes/application-vnd.asset-snapshot.sqlite3.png
    rm -f /usr/share/icons/hicolor/256x256/mimetypes/application-vnd.asset-snapshot.sqlite3.png
    if command -v gtk-update-icon-cache >/dev/null 2>&1; then
        gtk-update-icon-cache /usr/share/icons/hicolor || true
    fi
    if command -v gtk4-update-icon-cache >/dev/null 2>&1; then
        gtk4-update-icon-cache --force /usr/share/icons/hicolor || true
    fi
fi
