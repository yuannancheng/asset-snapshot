{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "asset-snapshot",
  "mainBinaryName": "asset-snapshot",
  "version": "0.2.10",
  "identifier": "com.asset-snapshot.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "资产快照",
        "width": 1180,
        "height": 780,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "category": "Finance",
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "asdb"
        ],
        "name": "Asset Snapshot Data File",
        "description": "资产快照数据文件",
        "mimeType": "application/vnd.asset-snapshot.sqlite3"
      }
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/share/mime/packages/asset-snapshot.xml": "deb/asset-snapshot.xml",
          "/usr/share/icons/hicolor/scalable/mimetypes/application-vnd.asset-snapshot.sqlite3.svg": "icons/asdb-file-icon.svg",
          "/usr/share/icons/hicolor/16x16/mimetypes/application-vnd.asset-snapshot.sqlite3.png": "icons/filetype/asdb-file-icon-16x16.png",
          "/usr/share/icons/hicolor/24x24/mimetypes/application-vnd.asset-snapshot.sqlite3.png": "icons/filetype/asdb-file-icon-24x24.png",
          "/usr/share/icons/hicolor/32x32/mimetypes/application-vnd.asset-snapshot.sqlite3.png": "icons/filetype/asdb-file-icon-32x32.png",
          "/usr/share/icons/hicolor/48x48/mimetypes/application-vnd.asset-snapshot.sqlite3.png": "icons/filetype/asdb-file-icon-48x48.png",
          "/usr/share/icons/hicolor/64x64/mimetypes/application-vnd.asset-snapshot.sqlite3.png": "icons/filetype/asdb-file-icon-64x64.png",
          "/usr/share/icons/hicolor/128x128/mimetypes/application-vnd.asset-snapshot.sqlite3.png": "icons/filetype/asdb-file-icon-128x128.png",
          "/usr/share/icons/hicolor/256x256/mimetypes/application-vnd.asset-snapshot.sqlite3.png": "icons/filetype/asdb-file-icon-256x256.png"
        },
        "postInstallScript": "deb/postinst",
        "postRemoveScript": "deb/postrm",
        "desktopTemplate": "deb/main.desktop"
      },
      "rpm": {
        "files": {
          "/usr/share/mime/packages/asset-snapshot.xml": "deb/asset-snapshot.xml",
          "/usr/share/icons/hicolor/scalable/mimetypes/application-vnd.asset-snapshot.sqlite3.svg": "icons/asdb-file-icon.svg",
          "/usr/share/icons/hicolor/16x16/mimetypes/application-vnd.asset-snapshot.sqlite3.png": "icons/filetype/asdb-file-icon-16x16.png",
          "/usr/share/icons/hicolor/24x24/mimetypes/application-vnd.asset-snapshot.sqlite3.png": "icons/filetype/asdb-file-icon-24x24.png",
          "/usr/share/icons/hicolor/32x32/mimetypes/application-vnd.asset-snapshot.sqlite3.png": "icons/filetype/asdb-file-icon-32x32.png",
          "/usr/share/icons/hicolor/48x48/mimetypes/application-vnd.asset-snapshot.sqlite3.png": "icons/filetype/asdb-file-icon-48x48.png",
          "/usr/share/icons/hicolor/64x64/mimetypes/application-vnd.asset-snapshot.sqlite3.png": "icons/filetype/asdb-file-icon-64x64.png",
          "/usr/share/icons/hicolor/128x128/mimetypes/application-vnd.asset-snapshot.sqlite3.png": "icons/filetype/asdb-file-icon-128x128.png",
          "/usr/share/icons/hicolor/256x256/mimetypes/application-vnd.asset-snapshot.sqlite3.png": "icons/filetype/asdb-file-icon-256x256.png"
        },
        "postInstallScript": "rpm/postinst",
        "postRemoveScript": "rpm/postrm",
        "desktopTemplate": "deb/main.desktop"
      }
    },
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "windows": {
      "nsis": {
        "template": "nsis/installer.nsi",
        "installerIcon": "icons/icon.ico",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": false,
        "customLanguageFiles": {
          "SimpChinese": "nsis/languages/SimpChinese.nsh",
          "TradChinese": "nsis/languages/TradChinese.nsh"
        },
        "startMenuFolder": "资产快照",
        "compression": "lzma"
      }
    },
    "resources": {
      "icons/asdb-file-icon.icns": "asdb-file-icon.icns",
      "icons/asdb-file-icon.ico": "asdb-file-icon.ico"
    }
  }
}
