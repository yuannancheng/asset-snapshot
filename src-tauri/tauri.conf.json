{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "asset-snapshot",
  "version": "0.2.4",
  "identifier": "com.asset-snapshot.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "资产快照",
        "width": 1180,
        "height": 780,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "category": "Finance",
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "asdb"
        ],
        "name": "Asset Snapshot Data File",
        "description": "资产快照数据文件",
        "mimeType": "application/vnd.asset-snapshot.sqlite3"
      }
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/share/mime/packages/asset-snapshot.xml": "deb/asset-snapshot.xml"
        },
        "postInstallScript": "deb/postinst",
        "postRemoveScript": "deb/postrm"
      },
      "rpm": {
        "files": {
          "/usr/share/mime/packages/asset-snapshot.xml": "deb/asset-snapshot.xml"
        },
        "postInstallScript": "rpm/postinst",
        "postRemoveScript": "rpm/postrm"
      }
    }
  }
}
