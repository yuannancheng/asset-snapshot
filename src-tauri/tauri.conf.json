{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "资产快照",
  "version": "0.2.2",
  "identifier": "com.asset-snapshot.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "资产快照",
        "width": 1180,
        "height": 780,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "windows": {
      "webviewInstallMode": "downloadBootstrapper"
    },
    "fileAssociations": [
      {
        "ext": [
          "as"
        ],
        "name": "Asset Snapshot Data File",
        "description": "资产快照数据文件",
        "mimeType": "application/vnd.asset-snapshot.sqlite3"
      }
    ]
  }
}
