#!/bin/sh
set -e

# Register MIME type for .asdb file association
if command -v update-mime-database >/dev/null 2>&1; then
    update-mime-database /usr/share/mime || true
fi

# Update desktop database so the file manager picks up the new MimeType
if command -v update-desktop-database >/dev/null 2>&1; then
    update-desktop-database /usr/share/applications || true
fi

# Update icon cache so the file manager picks up the MIME type icon
if command -v gtk-update-icon-cache >/dev/null 2>&1; then
    gtk-update-icon-cache --force /usr/share/icons/hicolor || true
fi

# GTK4 icon cache for modern GNOME/Ubuntu 24
if command -v gtk4-update-icon-cache >/dev/null 2>&1; then
    gtk4-update-icon-cache --force /usr/share/icons/hicolor || true
fi

# Yaru theme: on Ubuntu Nautilus hicolor fallback is broken (gnome #3341)
# so we also copy the MIME icon into Yaru directly
if [ -d "/usr/share/icons/Yaru" ]; then
    mkdir -p /usr/share/icons/Yaru/scalable/mimetypes
    cp /usr/share/icons/hicolor/scalable/mimetypes/application-vnd.asset-snapshot.sqlite3.svg \
       /usr/share/icons/Yaru/scalable/mimetypes/

    for s in 16x16 24x24 32x32 48x48 64x64 128x128 256x256; do
        if [ -f "/usr/share/icons/hicolor/$s/mimetypes/application-vnd.asset-snapshot.sqlite3.png" ]; then
            mkdir -p "/usr/share/icons/Yaru/$s/mimetypes"
            cp "/usr/share/icons/hicolor/$s/mimetypes/application-vnd.asset-snapshot.sqlite3.png" \
               "/usr/share/icons/Yaru/$s/mimetypes/"
        fi
    done

    if command -v gtk-update-icon-cache >/dev/null 2>&1; then
        gtk-update-icon-cache --force /usr/share/icons/Yaru || true
    fi
    if command -v gtk4-update-icon-cache >/dev/null 2>&1; then
        gtk4-update-icon-cache --force /usr/share/icons/Yaru || true
    fi
fi
